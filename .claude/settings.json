{
  "permissions": {
    "deny": [
      "Edit(.env*)",
      "Write(.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint 2>&1 | tail -20"
          }
        ]
      }
    ]
  }
}
